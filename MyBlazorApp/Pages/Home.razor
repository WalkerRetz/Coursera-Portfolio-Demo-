@page "/"

<PageTitle>Home - EventEase</PageTitle>

<div class=\"home-container\">
    <div class=\"hero-section\">
        <h1>Welcome to EventEase</h1>
        <p class=\"tagline\">Discover, Register, and Manage Corporate and Social Events</p>
        <p class=\"description\">EventEase makes it easy to browse and register for amazing events. Whether you're looking for networking opportunities, professional development, or social gatherings, we have something for everyone.</p>
        
        <div class=\"cta-buttons\">
            <NavLink href=\"/events\" class=\"btn-primary\">Browse Events</NavLink>
        </div>
    </div>
    
    <div class=\"features-section\">
        <h2>Why Choose EventEase?</h2>
        <div class=\"features-grid\">
            <div class=\"feature-card\">
                <div class=\"feature-icon\">📅</div>
                <h3>Easy Browsing</h3>
                <p>Discover events with detailed information about dates, locations, and descriptions.</p>
            </div>
            <div class=\"feature-card\">
                <div class=\"feature-icon\">👥</div>
                <h3>Quick Registration</h3>
                <p>Register for events in seconds and see real-time attendance counts.</p>
            </div>
            <div class=\"feature-card\">
                <div class=\"feature-icon\">🎯</div>
                <h3>Curated Events</h3>
                <p>Hand-picked corporate and social events tailored to your interests.</p>
            </div>
            <div class=\"feature-card\">
                <div class=\"feature-icon\">📱</div>
                <h3>Always Available</h3>
                <p>Access EventEase anytime, anywhere from any device.</p>
            </div>
        </div>
    </div>
</div>
